{
  "rewrites": [
    { "source": "/api/shorten",    "destination": "/api/shorten" },
    { "source": "/api/all",        "destination": "/api/all" },
    { "source": "/api/stats/(.*)", "destination": "/api/stats" },
    { "source": "/api/(.*)",       "destination": "/api/$1" },
    { "source": "/:code",          "destination": "/api/redirect" }
  ]
}
